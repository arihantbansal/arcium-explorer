# Database
DATABASE_URL=postgres://user:password@localhost:5432/arcium_explorer

# Solana RPC (server-side, with API keys)
DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
MAINNET_RPC_URL=https://poc-rpc.layer33.com

# Solana RPC (client-side, public)
NEXT_PUBLIC_DEVNET_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_MAINNET_RPC_URL=https://poc-rpc.layer33.com

# gRPC (Yellowstone/Geyser — mainnet only)
MAINNET_GRPC_ENDPOINT=https://poc-rpc.layer33.com:10000
MAINNET_GRPC_TOKEN=

# Worker config
ENABLE_MAINNET=true
ENABLE_DEVNET=true
LOG_LEVEL=info

# Worker intervals (ms) — all default to 5 minutes
# DEVNET_POLL_INTERVAL_MS=300000
# MAINNET_POLL_INTERVAL_MS=300000
# SNAPSHOT_INTERVAL_MS=300000
# HEARTBEAT_INTERVAL_MS=300000

# Snapshot retention (days, default 30)
# SNAPSHOT_RETENTION_DAYS=30

# TX enricher — separate RPC with tx history access (mainnet)
# MAINNET_ENRICHER_RPC_URL=

# WebSocket URLs (derived from RPC URLs if not set)
# MAINNET_WS_URL=
# DEVNET_WS_URL=

# Cron auth
CRON_SECRET=your-cron-secret-here
